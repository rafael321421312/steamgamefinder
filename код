    def search_via_steam_search(self, query):
        results = []
        try:
            url = "https://store.steampowered.com/search/"
            params = {"term": query, "category1": "998", "ignore_preferences": "1"}
            headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
            response = requests.get(url, params=params, headers=headers, timeout=10)

            if response.status_code == 200:
                pattern = r'href="(https://store\.steampowered\.com/app/(\d+)/[^"]+)"'
                matches = re.findall(pattern, response.text)
                seen = set()
                for full_url, appid in matches[:30]:
                    if appid not in seen:
                        seen.add(appid)
                        name = self.get_game_name_by_id(appid)
                        if name:
                            results.append({
                                "name": name,
                                "appid": appid,
                                "url": full_url.split('?')[0],
                                "genres": []
                            })
        except:
            pass
        return results

