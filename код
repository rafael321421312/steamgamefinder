    def get_real_price(self, appid):
        if appid in self.price_cache:
            cache_data = self.price_cache[appid]
            if time.time() - cache_data.get('timestamp', 0) < 3600:
                return cache_data

        try:
            url = "https://store.steampowered.com/api/appdetails"
            params = {"appids": appid, "cc": "ru"}
            headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
            response = requests.get(url, params=params, headers=headers, timeout=10)
            data = response.json()

            if data and str(appid) in data and data[str(appid)].get("success"):
                game_data = data[str(appid)]["data"]
                price_data = game_data.get("price_overview")
                result = {}

                if price_data:
                    current_price = price_data.get("final", 0) / 100
                    original_price = price_data.get("initial", 0) / 100
                    discount = price_data.get("discount_percent", 0)
                    result = {
                        "current_price": current_price,
                        "original_price": original_price,
                        "discount": discount,
                        "currency": price_data.get("currency", "RUB"),
                        "timestamp": time.time()
                    }
                elif game_data.get("is_free"):
                    result = {"is_free": True, "timestamp": time.time()}
                else:
                    result = None

                if result:
                    self.price_cache[appid] = result
                    self.save_cache()
                return result
        except Exception as e:
            print(f"Price error for {appid}: {e}")
        return None

