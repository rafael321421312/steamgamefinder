    def get_full_game_data(self, appid):
        try:
            url = "https://store.steampowered.com/api/appdetails"
            params = {"appids": appid, "cc": "ru", "l": "russian"}
            headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
            response = requests.get(url, params=params, headers=headers, timeout=10)
            data = response.json()

            if data and str(appid) in data and data[str(appid)].get("success"):
                game_data = data[str(appid)]["data"]

                genres = []
                if "genres" in game_data:
                    for genre in game_data["genres"]:
                        genres.append(genre.get("description", ""))

                pc_requirements = game_data.get("pc_requirements", {})
                if isinstance(pc_requirements, dict):
                    min_req = self.clean_requirements(pc_requirements.get("minimum", ""))
                    rec_req = self.clean_requirements(pc_requirements.get("recommended", ""))
                else:
                    min_req = self.clean_requirements(str(pc_requirements)) if pc_requirements else ""
                    rec_req = ""

                release_date_data = game_data.get("release_date", {})
                release_date = release_date_data.get("date", "Неизвестно")

                return {
                    "name": game_data.get("name", ""),
                    "has_demo": game_data.get("has_demo", False),
                    "genres": genres,
                    "developer": "Неизвестно",
                    "publisher": "Неизвестно",
                    "platforms": game_data.get("platforms", {}),
                    "minimum_requirements": min_req,
                    "recommended_requirements": rec_req,
                    "languages": game_data.get("supported_languages", "Не указано"),
                    "release_date": release_date,
                }
        except Exception as e:
            print(f"Error getting game data: {e}")
        return None

    def clean_requirements(self, req_text):
        if not req_text or len(req_text) < 5:
            return ""
        req_text = re.sub(r'<[^>]+>', ' ', req_text)
        req_text = re.sub(r'&nbsp;', ' ', req_text)
        req_text = re.sub(r'&lt;', '<', req_text)
        req_text = re.sub(r'&gt;', '>', req_text)
        req_text = re.sub(r'&amp;', '&', req_text)
        req_text = re.sub(r'\*', '', req_text)
        req_text = re.sub(r'\s+', ' ', req_text)
        return req_text[:500].strip()

    def get_price_history_demo(self, current_price):
        sales = []
        if current_price and current_price > 0:
            base_price = current_price
        else:
            base_price = 1000

        typical_sales = [
            ("Летняя распродажа", 70, 6),
            ("Зимняя распродажа", 75, 12),
            ("Осенняя распродажа", 60, 11),
            ("Весенняя распродажа", 55, 4),
        ]

        for name, discount, month in typical_sales:
            price = base_price * (1 - discount / 100)
            sales.append({"name": name, "discount": discount, "price": price, "month": month})
        return sorted(sales, key=lambda x: x['month'], reverse=True)

