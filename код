    def load_settings(self):
        self.current_theme = "dark"
        if os.path.exists(self.settings_file):
            try:
                with open(self.settings_file, 'r', encoding='utf-8') as f:
                    settings = json.load(f)
                    saved_theme = settings.get('theme', 'dark')
                    if saved_theme in self.themes:
                        self.current_theme = saved_theme
                    else:
                        self.current_theme = "dark"
            except:
                pass

    def save_settings(self):
        try:
            with open(self.settings_file, 'w', encoding='utf-8') as f:
                json.dump({'theme': self.current_theme}, f)
        except:
            pass

    def apply_theme(self, theme_name=None):
        if theme_name and theme_name in self.themes:
            self.current_theme = theme_name
            self.save_settings()
        elif theme_name and theme_name not in self.themes:
            self.current_theme = "dark"
            self.save_settings()
        if self.current_theme not in self.themes:
            self.current_theme = "dark"

        theme = self.themes[self.current_theme]

        self.root.configure(bg=theme["bg"])

        for widget in self.root.winfo_children():
            self._apply_theme_to_widget(widget, theme)

        style = ttk.Style()
        style.configure("TFrame", background=theme["bg"])
        style.configure("TLabel", background=theme["bg"], foreground=theme["fg"])
        style.configure("TButton", background=theme["secondary"], foreground=theme["fg"])
        style.configure("TCombobox", fieldbackground=theme["input_bg"], foreground=theme["fg"])

    def _apply_theme_to_widget(self, widget, theme):
        try:
            if isinstance(widget, tk.Frame):
                widget.configure(bg=theme["bg"])
            elif isinstance(widget, tk.LabelFrame):
                widget.configure(bg=theme["bg"], fg=theme["accent"])
                for child in widget.winfo_children():
                    self._apply_theme_to_widget(child, theme)
            elif isinstance(widget, tk.Label):
                important_colors = ["#e94560", "#ff9800", "#4caf50", "#ff6b6b", "#00bcd4", "#ffd700", "#4caf50"]
                current_fg = widget.cget("fg")
                if current_fg in important_colors:
                    widget.configure(bg=theme["bg"])
                else:
                    widget.configure(bg=theme["bg"], fg=theme["fg"])
            elif isinstance(widget, tk.Button):
                widget.configure(bg=theme["secondary"], fg=theme["fg"], activebackground=theme["accent"], activeforeground="white")
            elif isinstance(widget, tk.Entry):
                widget.configure(bg=theme["input_bg"], fg=theme["fg"], insertbackground=theme["fg"])
            elif isinstance(widget, scrolledtext.ScrolledText):
                widget.configure(bg=theme["text_bg"], fg=theme["fg"], insertbackground=theme["fg"])
                if hasattr(widget, 'vbar'):
                    widget.vbar.configure(bg=theme["secondary"], troughcolor=theme["bg"])
            elif isinstance(widget, tk.Listbox):
                widget.configure(bg=theme["list_bg"], fg=theme["fg"], selectbackground=theme["accent"], selectforeground="white")
            elif isinstance(widget, tk.Text):
                widget.configure(bg=theme["text_bg"], fg=theme["fg"], insertbackground=theme["fg"])
            elif isinstance(widget, ttk.Combobox):
                style = ttk.Style()
                style.configure("TCombobox", fieldbackground=theme["input_bg"], foreground=theme["fg"], background=theme["bg"])
            elif isinstance(widget, ttk.Progressbar):
                style = ttk.Style()
                style.configure("TProgressbar", background=theme["accent"], troughcolor=theme["secondary"])
            elif isinstance(widget, tk.Scrollbar):
                widget.configure(bg=theme["secondary"], troughcolor=theme["bg"], activebackground=theme["accent"])
            elif isinstance(widget, tk.Radiobutton):
                widget.configure(bg=theme["bg"], fg=theme["fg"], selectcolor=theme["secondary"], activebackground=theme["bg"])
            elif isinstance(widget, tk.Canvas):
                widget.configure(bg=theme["bg"])

            for child in widget.winfo_children():
                self._apply_theme_to_widget(child, theme)
        except Exception:
            pass

    def center_window(self):
        self.root.update_idletasks()
        width = 1300
