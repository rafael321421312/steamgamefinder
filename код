    def load_cache(self):
        if os.path.exists(self.cache_file):
            try:
                with open(self.cache_file, 'rb') as f:
                    cache = pickle.load(f)
                    now = time.time()
                    return {k: v for k, v in cache.items() if now - v.get('timestamp', 0) < 86400}
            except:
                return {}
        return {}

    def save_cache(self):
        try:
            with open(self.cache_file, 'wb') as f:
                pickle.dump(self.price_cache, f)
        except:
            pass

    def load_favorites(self):
        if os.path.exists(self.favorites_file):
            try:
                with open(self.favorites_file, 'r', encoding='utf-8') as f:
                    favorites = json.load(f)
                    for fav in favorites:
                        if 'price' not in fav:
                            fav['price'] = None
                    return favorites
            except:
                return []
        return []

    def save_favorites(self):
        try:
            with open(self.favorites_file, 'w', encoding='utf-8') as f:
                json.dump(self.favorites, f, ensure_ascii=False, indent=2)
        except:
            pass

    def update_favorite_prices(self):
        for fav in self.favorites:
            price_info = self.get_real_price(fav['appid'])
            if price_info:
                if price_info.get('is_free'):
                    fav['price'] = "БЕСПЛАТНО"
                elif price_info.get('current_price'):
                    if price_info.get('discount', 0) > 0:
                        fav['price'] = f"{price_info['current_price']:.2f} RUB (-{price_info['discount']}%)"
                    else:
                        fav['price'] = f"{price_info['current_price']:.2f} RUB"
            else:
                fav['price'] = "Игра еще не вышла"
        self.save_favorites()

