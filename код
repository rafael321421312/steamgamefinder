    def perform_real_search(self, query):
        try:
            url = "https://store.steampowered.com/search/suggest"
            params = {"term": query, "f": "games", "cc": "RU", "l": "russian"}
            headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}

            response = requests.get(url, params=params, headers=headers, timeout=10)
            results = []

            if response.status_code == 200:
                try:
                    data = response.json()
                    if "items" in data:
                        for item in data["items"]:
                            if "name" in item and "id" in item:
                                results.append({
                                    "name": item["name"],
                                    "appid": str(item["id"]),
                                    "url": f"https://store.steampowered.com/app/{item['id']}/",
                                    "genres": []
                                })
                except:
                    pass

            if len(results) == 0:
                results = self.search_via_steam_search(query)

            if len(results) == 0:
                results = self.search_in_popular_games(query)

            if results:
                available_genres = set()
                for game in results:
                    price_info = self.get_real_price(game['appid'])
                    game['price_info'] = price_info

                    genres = self.get_game_genres(game['appid'])
                    game['genres'] = genres
                    for genre in genres:
                        available_genres.add(genre)

                self.root.after(0, self.update_genre_list, available_genres)
                self.original_results = results.copy()
                self.filtered_results = results.copy()
                self.root.after(0, self.apply_sorting)
            else:
                self.root.after(0, self.no_results)

        except Exception as e:
            print(f"Search error: {e}")
            self.root.after(0, self.search_error, str(e))
        finally:
            self.root.after(0, self.stop_loading)

    def get_game_genres(self, appid):
