            self.info_text.insert(tk.END, "Выберите игру для просмотра характеристик", "warning")
            return

        self.info_text.insert(tk.END, f"⚙️ Системные требования: {self.current_game_name}\n", "title")
        self.info_text.insert(tk.END, "─" * 60 + "\n\n", "separator")

        if self.current_full_info:
            info = self.current_full_info

            min_req = info.get('minimum_requirements', '')
            if min_req and len(min_req) > 5:
                self.info_text.insert(tk.END, "Минимальные:\n", "specs_title")
                lines = min_req.split('\n')
                seen_fields = set()
                unique_lines = []
                for line in lines:
                    if line.strip():
                        field = line.split(':', 1)[0].strip() if ':' in line else line
                        if field not in seen_fields:
                            seen_fields.add(field)
                            unique_lines.append(line)

                for line in unique_lines:
                    if line.strip():
                        if ':' in line:
                            parts = line.split(':', 1)
                            field = parts[0].strip()
                            value = parts[1].strip()
                            self.info_text.insert(tk.END, f"{field}: {value}\n")
                        else:
                            self.info_text.insert(tk.END, f"{line}\n")
                self.info_text.insert(tk.END, "\n")
            else:
                self.info_text.insert(tk.END, "Минимальные:\n", "specs_title")
                self.info_text.insert(tk.END, "   Не указаны\n\n")

            rec_req = info.get('recommended_requirements', '')
            if rec_req and len(rec_req) > 5:
                self.info_text.insert(tk.END, "Рекомендованные:\n", "specs_title")
                lines = rec_req.split('\n')
                seen_fields = set()
                unique_lines = []
                for line in lines:
                    if line.strip():
                        field = line.split(':', 1)[0].strip() if ':' in line else line
                        if field not in seen_fields:
                            seen_fields.add(field)
                            unique_lines.append(line)

                for line in unique_lines:
                    if line.strip():
                        if ':' in line:
                            parts = line.split(':', 1)
                            field = parts[0].strip()
                            value = parts[1].strip()
                            self.info_text.insert(tk.END, f"{field}: {value}\n")
                        else:
                            self.info_text.insert(tk.END, f"{line}\n")
                self.info_text.insert(tk.END, "\n")
            else:
                self.info_text.insert(tk.END, "Рекомендованные:\n", "specs_title")
                self.info_text.insert(tk.END, "   Не указаны\n\n")
        else:
            self.info_text.insert(tk.END, "Характеристики игры недоступны", "warning")

    def add_to_favorites(self):
        selection = self.results_listbox.curselection()
        if not selection or selection[0] >= len(self.current_results):
            messagebox.showwarning("Внимание", "Выберите игру из списка")
            return

        game = self.current_results[selection[0]]
        if game is None:
            return

        for fav in self.favorites:
            if fav['appid'] == game['appid']:
                messagebox.showinfo("Информация", f"Игра '{game['name']}' уже в избранном")
                return

        price_info = self.get_real_price(game['appid'])
        price_text = None
        if price_info:
            if price_info.get('is_free'):
                price_text = "БЕСПЛАТНО"
            elif price_info.get('current_price'):
                if price_info.get('discount', 0) > 0:
                    price_text = f"{price_info['current_price']:.2f} RUB (-{price_info['discount']}%)"
                else:
                    price_text = f"{price_info['current_price']:.2f} RUB"

        self.favorites.append({
            'name': game['name'],
            'appid': game['appid'],
            'url': game['url'],
            'price': price_text,
            'added_date': datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            'note': ""
        })
        self.save_favorites()
        messagebox.showinfo("Успех", f"Игра '{game['name']}' добавлена в избранное!")

    def open_selected_game(self):
        selection = self.results_listbox.curselection()
        if selection and selection[0] < len(self.current_results):
            game = self.current_results[selection[0]]
            if game:
                webbrowser.open(game['url'])
                self.status_var.set(f"🌐 Открыта страница: {game['name']}")

    def open_steamdb(self):
        if self.selected_appid:
            webbrowser.open(f"https://steamdb.info/app/{self.selected_appid}/")
            self.status_var.set(f"🌐 Открыт SteamDB для ID: {self.selected_appid}")

    def refresh_prices(self):
        if self.selected_appid:
            if self.selected_appid in self.price_cache:
                del self.price_cache[self.selected_appid]
            self.get_real_price(self.selected_appid)
            self.load_game_data(self.selected_appid, self.current_game_name)
            self.status_var.set("🔄 Цены обновлены")

    def no_results(self):
        self.status_var.set("❌ Игры не найдены. Попробуйте другое название.")
        self.info_text.delete(1.0, tk.END)
        self.info_text.insert(tk.END, "❌ ИГРЫ НЕ НАЙДЕНЫ\n\n", "warning")
        self.info_text.insert(tk.END, "Попробуйте:\n\n", "recommendation")
        self.info_text.insert(tk.END, "• Ввести название на английском\n", "price")
        self.info_text.insert(tk.END, "• Проверить правильность написания\n", "price")
        self.info_text.insert(tk.END, "• Попробовать более короткий запрос\n\n", "price")
        self.info_text.insert(tk.END, "💡 Примеры: Portal, Dota 2, counter strike, Half-Life 2\n", "demo")

    def search_error(self, error_msg):
        self.status_var.set(f"❌ Ошибка: {error_msg}")
        self.info_text.delete(1.0, tk.END)
        self.info_text.insert(tk.END, "❌ ОШИБКА ПОИСКА\n\n", "warning")
        self.info_text.insert(tk.END, f"{error_msg}\n\n", "price")
        self.info_text.insert(tk.END, "Проверьте подключение к интернету и попробуйте снова.", "demo")


def main():
    root = tk.Tk()
    app = SteamGameFinder(root)

    def on_closing():
        app.save_cache()
        app.save_favorites()
        app.save_settings()
        root.destroy()

    root.protocol("WM_DELETE_WINDOW", on_closing)
    root.mainloop()


if __name__ == "__main__":
    main()
