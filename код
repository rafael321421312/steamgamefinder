    def reset_filters(self):
        self.genre_filter_var.set("Все жанры")
        self.sort_by.set("relevance")
        self.selected_genres.clear()
        self.apply_filtering()

    def on_genre_filter(self, event=None):
        selected = self.genre_filter_var.get()
        if selected == "Все жанры":
            self.selected_genres.clear()
        else:
            self.selected_genres = {selected}
        self.apply_filtering()

    def apply_filtering(self):
        if not self.original_results:
            return

        if self.selected_genres:
            filtered = []
            for game in self.original_results:
                if game is None:
                    continue
                game_genres = game.get('genres', [])
                if any(genre in self.selected_genres for genre in game_genres):
                    filtered.append(game)
        else:
            filtered = self.original_results.copy()

        self.filtered_results = filtered

        sort_type = self.sort_by.get()
        if sort_type != "relevance":
            try:
                if sort_type == "price_asc":
                    filtered.sort(key=lambda x: x.get('price_info', {}).get('current_price', 999999)
                    if x.get('price_info') and isinstance(x.get('price_info'), dict)
                       and not x['price_info'].get('is_free') else 999999)
                elif sort_type == "price_desc":
                    filtered.sort(key=lambda x: x.get('price_info', {}).get('current_price', 0)
                    if x.get('price_info') and isinstance(x.get('price_info'), dict)
                       and not x['price_info'].get('is_free') else 0, reverse=True)
                elif sort_type == "discount":
                    filtered.sort(key=lambda x: x.get('price_info', {}).get('discount', 0)
                    if x.get('price_info') and isinstance(x.get('price_info'), dict) else 0, reverse=True)
            except Exception as e:
                print(f"Sorting error: {e}")

        self.display_real_results(filtered)

    def apply_sorting(self):
        if not self.original_results:
            return

        sort_type = self.sort_by.get()
        results = self.original_results.copy()

        if sort_type != "relevance":
            try:
                if sort_type == "price_asc":
                    results.sort(key=lambda x: x.get('price_info', {}).get('current_price', 999999)
                    if x.get('price_info') and isinstance(x.get('price_info'), dict)
                       and not x['price_info'].get('is_free') else 999999)
                elif sort_type == "price_desc":
                    results.sort(key=lambda x: x.get('price_info', {}).get('current_price', 0)
                    if x.get('price_info') and isinstance(x.get('price_info'), dict)
                       and not x['price_info'].get('is_free') else 0, reverse=True)
                elif sort_type == "discount":
                    results.sort(key=lambda x: x.get('price_info', {}).get('discount', 0)
                    if x.get('price_info') and isinstance(x.get('price_info'), dict) else 0, reverse=True)
            except Exception as e:
                print(f"Sorting error: {e}")

        self.filtered_results = results
        self.display_real_results(results)

