            params = {"appids": appid, "cc": "ru", "l": "russian"}
            headers = {'User-Agent': 'Mozilla/5.0'}
            response = requests.get(url, params=params, headers=headers, timeout=5)
            data = response.json()
            if data and str(appid) in data and data[str(appid)].get("success"):
